/**
 * XZAI Push Notifications — Grok-Style Design
 */
(function() {
  if (!('Notification' in window)) return;
  if (window.location.pathname.includes('admin')) return;
  if (localStorage.getItem('xz-notif-denied')) return;

  // إضافة CSS
  const style = document.createElement('style');
  style.textContent = `
    @keyframes xz-slide-up {
      from { opacity:0; transform:translateY(20px) scale(.96); }
      to   { opacity:1; transform:translateY(0) scale(1); }
    }
    @keyframes xz-pulse-dot {
      0%,100% { transform:scale(1); opacity:1; }
      50%      { transform:scale(1.4); opacity:.7; }
    }
    #xz-notif-banner * { box-sizing:border-box; font-family:'SF Pro Display',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
    #xz-notif-banner {
      position:fixed; bottom:28px; right:28px; z-index:99999;
      width:360px;
      background:#000;
      border:1px solid rgba(255,255,255,.12);
      border-radius:20px;
      padding:0;
      overflow:hidden;
      box-shadow:0 32px 80px rgba(0,0,0,.8), 0 0 0 1px rgba(255,255,255,.04) inset;
      animation:xz-slide-up .35s cubic-bezier(.16,1,.3,1) forwards;
    }
    #xz-notif-banner .xn-header {
      display:flex; align-items:center; gap:10px;
      padding:18px 20px 14px;
      border-bottom:1px solid rgba(255,255,255,.06);
    }
    #xz-notif-banner .xn-icon {
      width:36px; height:36px; border-radius:10px;
      background:#fff;
      display:flex; align-items:center; justify-content:center;
      flex-shrink:0;
    }
    #xz-notif-banner .xn-icon svg { width:20px; height:20px; }
    #xz-notif-banner .xn-app-name {
      font-size:13px; font-weight:700; color:#fff; letter-spacing:-.01em;
    }
    #xz-notif-banner .xn-dot {
      width:7px; height:7px; border-radius:50%;
      background:#00d26a;
      margin-left:auto;
      animation:xz-pulse-dot 2s ease infinite;
      box-shadow:0 0 8px rgba(0,210,106,.6);
    }
    #xz-notif-banner .xn-body { padding:16px 20px; }
    #xz-notif-banner .xn-title {
      font-size:15px; font-weight:700; color:#fff;
      letter-spacing:-.02em; line-height:1.3; margin-bottom:6px;
    }
    #xz-notif-banner .xn-desc {
      font-size:13px; color:rgba(255,255,255,.45);
      line-height:1.5; margin-bottom:18px;
    }
    #xz-notif-banner .xn-actions {
      display:flex; gap:8px;
    }
    #xz-notif-allow {
      flex:1; padding:11px 0;
      background:#fff; color:#000;
      border:none; border-radius:12px;
      font-size:13px; font-weight:700;
      cursor:pointer; letter-spacing:-.01em;
      transition:all .15s ease;
    }
    #xz-notif-allow:hover { background:rgba(255,255,255,.88); transform:scale(.98); }
    #xz-notif-deny {
      padding:11px 18px;
      background:rgba(255,255,255,.06); color:rgba(255,255,255,.5);
      border:1px solid rgba(255,255,255,.08); border-radius:12px;
      font-size:13px; font-weight:600;
      cursor:pointer;
      transition:all .15s ease;
    }
    #xz-notif-deny:hover { background:rgba(255,255,255,.1); color:rgba(255,255,255,.7); }
    #xz-notif-banner .xn-footer {
      padding:10px 20px 14px;
      font-size:11px; color:rgba(255,255,255,.2);
      letter-spacing:.02em; text-align:center;
    }
    /* Success state */
    #xz-notif-banner.success .xn-body { text-align:center; padding:28px 24px; }
    #xz-notif-banner.success .xn-check {
      width:48px; height:48px; border-radius:50%;
      background:#00d26a;
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 14px;
      font-size:22px;
    }
    @media(max-width:480px){
      #xz-notif-banner { width:calc(100vw - 32px); right:16px; bottom:16px; }
    }
  `;
  document.head.appendChild(style);

  setTimeout(() => {
    if (Notification.permission === 'default') showBanner();
  }, 12000);

  function showBanner() {
    const banner = document.createElement('div');
    banner.id = 'xz-notif-banner';
    banner.innerHTML = `
      <div class="xn-header">
        <div class="xn-icon">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" fill="#000"/>
          </svg>
        </div>
        <div>
          <div class="xn-app-name">XZAI</div>
          <div style="font-size:11px;color:rgba(255,255,255,.35);margin-top:1px">AI News & Intelligence</div>
        </div>
        <div class="xn-dot"></div>
      </div>
      <div class="xn-body">
        <div class="xn-title">Never Miss a Breaking AI Story</div>
        <div class="xn-desc">Get instant notifications when GPT-5, Gemini, Claude or any major AI model drops. Real-time. No spam.</div>
        <div class="xn-actions">
          <button id="xz-notif-allow">Allow Notifications</button>
          <button id="xz-notif-deny">Not now</button>
        </div>
      </div>
      <div class="xn-footer">You can change this anytime in your browser settings</div>
    `;
    document.body.appendChild(banner);

    document.getElementById('xz-notif-allow').onclick = async () => {
      const perm = await Notification.requestPermission();
      if (perm === 'granted') {
        localStorage.setItem('xz-notif', '1');
        banner.innerHTML = `
          <div class="xn-body" style="text-align:center;padding:32px 24px">
            <div style="width:52px;height:52px;border-radius:50%;background:#00d26a;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:24px;box-shadow:0 0 24px rgba(0,210,106,.4)">✓</div>
            <div style="font-size:16px;font-weight:700;color:#fff;margin-bottom:6px">You're all set</div>
            <div style="font-size:13px;color:rgba(255,255,255,.4)">Breaking AI news will come straight to you.</div>
          </div>`;
        setTimeout(() => banner.remove(), 2500);
        new Notification('XZAI — Notifications Active', {
          body: "You'll get alerts for GPT-5, Claude 4, Gemini Ultra and all major AI news.",
          icon: '/images/logo-xzai.webp'
        });
      } else {
        banner.remove();
      }
    };

    document.getElementById('xz-notif-deny').onclick = () => {
      banner.style.animation = 'none';
      banner.style.opacity = '0';
      banner.style.transform = 'translateY(12px)';
      banner.style.transition = 'all .2s ease';
      setTimeout(() => banner.remove(), 200);
      localStorage.setItem('xz-notif-denied', '1');
    };
  }

  // إشعار دوري للأخبار
  if (Notification.permission === 'granted' && localStorage.getItem('xz-notif')) {
    setInterval(async () => {
      try {
        const last = localStorage.getItem('xz-last-notif') || '0';
        const r = await fetch(
          `${window.XZAI_CONFIG?.supabase?.url}/rest/v1/ai_articles?published_at=gt.${new Date(+last).toISOString()}&status=eq.published&limit=1&order=published_at.desc&select=title`,
          { headers: { apikey: window.XZAI_CONFIG?.supabase?.anonKey } }
        );
        const d = await r.json();
        if (d?.length) {
          new Notification('⚡ Breaking AI News — XZAI', {
            body: d[0].title,
            icon: '/images/logo-xzai.webp'
          });
        }
        localStorage.setItem('xz-last-notif', Date.now().toString());
      } catch {}
    }, 3600000);
  }
})();
